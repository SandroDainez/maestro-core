generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(uuid())
  slug      String   @unique
  name      String
  createdAt DateTime @default(now())

  projects Project[]
  users    TenantUser[]
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String?
  role         String   @default("Member")
  status       String   @default("active")
  passwordHash String?
  createdAt    DateTime @default(now())

  tenants TenantUser[]
}

model TenantUser {
  id       String @id @default(uuid())
  userId   String
  tenantId String

  user   User   @relation(fields: [userId], references: [id])
  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([userId, tenantId])
}

model Project {
  id        String   @id @default(uuid())
  slug      String   @unique
  name      String
  path      String
  status    String
  createdAt DateTime @default(now())

  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  pipelineRuns     PipelineRun[]
  productAnalyses  ProductAnalysis[]
}

model PipelineRun {
  id         String   @id @default(uuid())
  projectId  String
  type       String
  status     String
  startedAt  DateTime
  finishedAt DateTime?

  score      Int?
  riskLevel  String?
  analysis   Json?

  project Project @relation(fields: [projectId], references: [id])
  phaseRuns PipelinePhaseRun[]
}

model PipelinePhaseRun {
  id         String   @id @default(uuid())
  runId      String
  phase      String
  status     String
  logs       Json?
  error      String?
  details    String?
  outputs    Json?
  startedAt  DateTime @default(now())
  finishedAt DateTime?

  run PipelineRun @relation(fields: [runId], references: [id])

  @@index([runId])
}

model ProductAnalysis {
  id                  String   @id @default(uuid())

  projectId           String
  project             Project  @relation(fields: [projectId], references: [id])

  overallScore        Int
  stabilityScore      Int
  architectureScore   Int
  securityScore       Int
  maturityScore       Int

  riskLevel           String   // LOW | MODERATE | HIGH | CRITICAL

  details             Json?    // relatório completo estruturado

  createdAt           DateTime @default(now())

  @@index([projectId])
}

model DeletionAudit {
  id          String   @id @default(cuid())
  projectId   String?
  projectSlug String?
  userId      String?
  userEmail   String?
  runId       String?
  targetType  String   @default("project")
  performedBy String
  reason      String?
  deletedAt   DateTime @default(now())
}
